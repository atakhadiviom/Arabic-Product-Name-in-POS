<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Arabic Name field to product template form view -->
    <record id="product_template_form_view_arabic" model="ir.ui.view">
        <field name="name">product.template.form.arabic</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="arabic_name" placeholder="Arabic product name..."/>
            </xpath>
        </field>
    </record>

    <!-- Add Arabic Name column to product template tree view -->
    <record id="product_template_tree_view_arabic" model="ir.ui.view">
        <field name="name">product.template.tree.arabic</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="arabic_name" optional="hide"/>
            </field>
        </field>
    </record>

    <!-- Add Arabic Name field to product variant form view -->
    <record id="product_product_form_view_arabic" model="ir.ui.view">
        <field name="name">product.product.form.arabic</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="arabic_name" placeholder="Arabic product name..."/>
            </xpath>
        </field>
    </record>

    <!-- Add Arabic Name column to product variant tree view -->
    <record id="product_product_tree_view_arabic" model="ir.ui.view">
        <field name="name">product.product.tree.arabic</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="arabic_name" optional="hide"/>
            </field>
        </field>
    </record>
</odoo>

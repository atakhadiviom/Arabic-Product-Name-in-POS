<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Product Item Template - Show Arabic Name below product name -->
    <t t-name="arabic_product_pos.ProductItem" t-inherit="point_of_sale.ProductItem" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-name')]" position="after">
            <t t-if="props.product.arabic_name and pos.config.show_arabic_product_names">
                <div class="product-name-arabic" t-esc="props.product.arabic_name"/>
            </t>
        </xpath>
    </t>

    <!-- Orderline Template - Show Arabic Name in order lines -->
    <t t-name="arabic_product_pos.Orderline" t-inherit="point_of_sale.Orderline" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-name')]" position="after">
            <t t-if="props.line.product.arabic_name and pos.config.show_arabic_product_names">
                <div class="line-name-arabic" t-esc="props.line.product.arabic_name"/>
            </t>
        </xpath>
    </t>

    <!-- Receipt Template - Show Arabic Name in receipts -->
    <t t-name="arabic_product_pos.ReceiptLine" t-inherit="point_of_sale.ReceiptLine" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-name')]" position="inside">
            <t t-if="props.line.product.arabic_name and pos.config.show_arabic_product_names">
                <div class="receipt-line-arabic" t-esc="props.line.product.arabic_name"/>
            </t>
        </xpath>
    </t>
</odoo>

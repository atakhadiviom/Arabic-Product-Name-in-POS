<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Arabic Name option to POS config form view -->
    <record id="pos_config_form_view_arabic" model="ir.ui.view">
        <field name="name">pos.config.form.arabic</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Arabic Product Names">
                    <group>
                        <field name="show_arabic_product_names"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
